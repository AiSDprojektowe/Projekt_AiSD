<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Projekt_AiSD.GUI.MainWindow"
        Title="Panel Wizualizacji Planu Zajęć - Moduł 4"
        Width="1000" Height="750"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *, 150">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="15">
            <Button Name="LoadDataBtn" Content="Wczytaj dane i parsuj LLM" Click="LoadDataBtn_Click" Padding="10,5" />
            <Button Name="RunOptimizationBtn" Content="Uruchom Silnik Optymalizacji" Click="RunOptimizationBtn_Click" IsEnabled="False" Padding="10,5" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="10,0,10,0">
            <TabItem Header="Siatka Planu">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Wygenerowany Plan Zajęć Uczelni" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Margin="0,0,0,15"
                               Foreground="#2b2b2b"/>

                    <DataGrid Grid.Row="1" 
                              Name="PlanDataGrid" 
                              x:CompileBindings="False"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              BorderThickness="1" 
                              BorderBrush="#cccccc"
                              >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dzień" Binding="{Binding DayName}" Width="120" />
                            <DataGridTextColumn Header="Godziny" Binding="{Binding TimeRange}" Width="120" />
                            <DataGridTextColumn Header="Przedmiot" Binding="{Binding CourseName}" Width="*" />
                            <DataGridTextColumn Header="Grupa" Binding="{Binding GroupName}" Width="100" />
                            <DataGridTextColumn Header="Prowadzący" Binding="{Binding InstructorName}" Width="250" />
                            <DataGridTextColumn Header="Sala" Binding="{Binding RoomName}" Width="200" />
                        </DataGrid.Columns>
</DataGrid> 
                </Grid>
            </TabItem>

            <TabItem Header="Wykres Zbieżności">
                         <Image x:Name="ConvergencePlotImage" Stretch="Uniform" Margin="10"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Margin="15" BorderBrush="#333333" BorderThickness="2" Background="#1e1e1e">
            <ScrollViewer>
                <TextBlock Name="LogConsole" 
                           Text="System gotowy do pracy. Oczekuję na wczytanie danych..." 
                           Margin="10" 
                           TextWrapping="Wrap" 
                           FontFamily="Consolas" 
                           Foreground="#4CAF50" /> </ScrollViewer>
        </Border>

    </Grid>
</Window>
